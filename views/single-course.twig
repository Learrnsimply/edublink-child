<!doctype html>
<html lang="ar" dir="rtl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{{ course_title }} - {{ site.name }}</title>
    {{ fn('wp_head') }}
  </head>
  <body class="learnsimply-homepage-body">
    
    {% include 'components/header.twig' %}

    <main class="course-main-content">
      <div class="container">

        {# ===== HERO SECTION ===== #}
        <div class="course-hero">
          
          {# Right: Course Info #}
          <div class="course-info-section">
            
            {# Breadcrumb #}
            <div class="course-breadcrumb">
              <a href="{{ site.url }}">الرئيسية</a>
              <span class="breadcrumb-sep">/</span>
              <a href="{{ site.url }}/courses">الكورسات</a>
              <span class="breadcrumb-sep">/</span>
              <span class="breadcrumb-current">{{ course_title }}</span>
            </div>

            {# Badges #}
            <div class="course-badges">
              <span class="badge badge-type">كورس</span>
              <span class="badge badge-rating">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="#ffbb54"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                {{ rating_avg }} ({{ rating_count }} تقييم)
              </span>
              <span class="badge badge-level">{{ course_level }}</span>
            </div>

            {# Title #}
            <h1 class="course-title">{{ course_title }}</h1>

            {# Description #}
            <div class="course-description">
              {% set descText = course_excerpt ?: course_content|striptags %}
              {{ descText|slice(0, 200) }}{% if descText|length > 200 %}...{% endif %}
            </div>

            {# Instructor Mini Card #}
            {% if instructors|length > 0 %}
            <div class="instructor-mini">
              <div class="instructor-mini-avatar">
                <img src="{{ instructors[0].avatar ?: theme_uri ~ '/assets/img/ellipse1.png' }}" alt="{{ instructors[0].name }}" />
              </div>
              <div class="instructor-mini-info">
                <p class="instructor-mini-name">{{ instructors[0].name }}</p>
                <p class="instructor-mini-role">+7 سنين خبرة</p>
              </div>
            </div>
            {% endif %}

            {# Stats Row #}
            <div class="course-stats-row">
              <div class="stat-chip">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#999eb2" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M12 8V12L14.5 14.5" stroke-linecap="round"/></svg>
                <span>{{ course_duration ?: 'غير محدد' }}</span>
              </div>
              <div class="stat-chip">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#999eb2" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="3"/><path d="M9 12l2 2 4-4" stroke-linecap="round" stroke-linejoin="round"/></svg>
                <span>{{ content_count }} محتوى</span>
              </div>
              <div class="stat-chip">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#999eb2" stroke-width="1.5"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4-4v2"/><circle cx="9" cy="7" r="4"/></svg>
                <span>+{{ students_count }} طالب</span>
              </div>
              {% if has_certificate %}
              <div class="stat-chip">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#999eb2" stroke-width="1.5"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89L17 22l-5-3-5 3 1.523-9.11"/></svg>
                <span>شهادة إتمام</span>
              </div>
              {% endif %}
            </div>

            {# Media: Video or Image #}
            <div class="single-course-media">
              {% if course_video %}
                <div class="single-course-video">
                  {% if course_video.source == 'youtube' and course_video.embed_url %}
                    <iframe src="{{ course_video.embed_url }}" frameborder="0" allowfullscreen allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" title="{{ course_title }}"></iframe>
                  {% elseif course_video.source == 'vimeo' and course_video.embed_url %}
                    <iframe src="{{ course_video.embed_url }}" frameborder="0" allowfullscreen allow="autoplay; fullscreen; picture-in-picture" title="{{ course_title }}"></iframe>
                  {% elseif course_video.source == 'embedded' and course_video.embed_code %}
                    {{ course_video.embed_code|raw }}
                  {% elseif course_video.url %}
                    <video controls playsinline {% if course_video.poster %}poster="{{ course_video.poster }}"{% endif %}>
                      <source src="{{ course_video.url }}" type="{{ course_video.type|default('video/mp4') }}" />
                    </video>
                  {% else %}
                    <img src="{{ course_image }}" alt="{{ course_title }}" />
                  {% endif %}
                </div>
              {% else %}
                <div class="single-course-image">
                  <img src="{{ course_image }}" alt="{{ course_title }}" />
                </div>
              {% endif %}
            </div>
          </div>

          {# Left: Purchase Card (Sticky) #}
          <div class="purchase-card-wrapper">
            <div class="purchase-card">
              
              {# Discount Banner #}
              {% if discount_percent > 0 %}
              <div class="purchase-discount-banner">
                خصم {{ discount_percent }}% — العرض لفترة محدودة!
              </div>
              {% endif %}

              {# Price #}
              <div class="purchase-price-section">
                <div class="purchase-price-row">
                  {% if sale_price_formatted %}
                    <span class="purchase-current-price">{{ sale_price_formatted }}</span>
                    <span class="purchase-currency">جنيه مصري</span>
                  {% elseif regular_price_formatted %}
                    <span class="purchase-current-price">{{ regular_price_formatted }}</span>
                    <span class="purchase-currency">جنيه مصري</span>
                  {% else %}
                    <span class="purchase-current-price purchase-free">مجاني</span>
                  {% endif %}
                </div>
                {% if discount_percent > 0 and regular_price_formatted %}
                <div class="purchase-old-row">
                  <span class="purchase-old-price">{{ regular_price_formatted }} جنيه</span>
                  <span class="purchase-discount-badge">خصم {{ discount_percent }}%</span>
                </div>
                {% endif %}
              </div>

              {# CTA Button #}
              <div class="purchase-cta">
                {% if is_enrolled %}
                  {% if lesson_url %}
                  <a href="{{ lesson_url }}" class="purchase-btn purchase-btn-enrolled">ابدأ التعلم</a>
                  {% endif %}
                {% elseif is_public %}
                  {% if lesson_url %}
                  <a href="{{ lesson_url }}" class="purchase-btn purchase-btn-enrolled">ابدأ التعلم</a>
                  {% endif %}
                {% elseif is_purchasable and not is_free %}
                  {% if product_id %}
                  <a href="{{ cart_url|default(site.url ~ '/cart-1/') }}?add-to-cart={{ product_id }}" class="purchase-btn">اشتر الآن</a>
                  {% else %}
                  <button class="purchase-btn" onclick="enrollCourse()">سجل الآن</button>
                  {% endif %}
                {% else %}
                  <button class="purchase-btn" onclick="enrollCourse()">سجل الآن</button>
                {% endif %}

                <button class="purchase-share-btn" onclick="shareCourse()">
                  <svg width="18" height="18" fill="none" viewBox="0 0 24 24">
                    <path d="M14.6644 5.47875L18.6367 9.00968C20.2053 10.404 20.9896 11.1012 20.9896 11.9993C20.9896 12.8975 20.2053 13.5946 18.6367 14.989L14.6644 18.5199C13.9484 19.1563 13.5903 19.4746 13.2952 19.342C13 19.2095 13 18.7305 13 17.7725V15.4279C9.4 15.4279 5.5 17.1422 4 19.9993C4 10.8565 9.33333 8.57075 13 8.57075V6.22616C13 5.26817 13 4.78917 13.2952 4.65662C13.5903 4.52407 13.9484 4.8423 14.6644 5.47875Z" stroke="#999EB2" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" />
                  </svg>
                </button>
              </div>

              {# Features Mini List #}
              {% if first_five_contents|length > 0 %}
              <div class="purchase-features">
                <p class="purchase-features-title">يتضمن الكورس:</p>
                {% for content in first_five_contents %}
                <div class="purchase-feature-item">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="#4077f3"><circle cx="12" cy="12" r="10"/><path d="M10.58 15.58C10.38 15.58 10.19 15.5 10.05 15.36L7.22 12.53C6.93 12.24 6.93 11.76 7.22 11.47C7.51 11.18 7.99 11.18 8.28 11.47L10.58 13.77L15.72 8.63C16.01 8.34 16.49 8.34 16.78 8.63C17.07 8.92 17.07 9.4 16.78 9.69L11.11 15.36C10.97 15.5 10.78 15.58 10.58 15.58Z" fill="#fff"/></svg>
                  <span>{{ content.title }}</span>
                </div>
                {% endfor %}
              </div>
              {% endif %}

              {# Students Avatars #}
              <div class="purchase-students">
                <div class="students-avatars">
                  {% if students_avatars|length > 0 %}
                    {% for student in students_avatars|slice(0, 3) %}
                      <img class="avatar" src="{{ student.avatar }}" alt="{{ student.name ?: 'Student' }}" />
                    {% endfor %}
                  {% else %}
                    <img class="avatar" src="{{ theme_uri }}/assets/img/ellipse1.png" alt="Student" />
                    <img class="avatar" src="{{ theme_uri }}/assets/img/ellipse2.png" alt="Student" />
                    <img class="avatar" src="{{ theme_uri }}/assets/img/ellipse3.png" alt="Student" />
                  {% endif %}
                  <div class="avatar-badge">{{ students_count }}+</div>
                </div>
                <span class="purchase-students-text">طالب مشترك</span>
              </div>
            </div>
          </div>
        </div>

        {# ===== COURSE DESCRIPTION ===== #}
        {% if course_content %}
        <div class="section-card description-card">
          <div class="card-content">
            <div class="section-header">
              <div class="section-icon-box">
                <svg width="24" height="24" fill="none" viewBox="0 0 24 24"><path d="M12 22C6.477 22 2 17.523 2 12S6.477 2 12 2s10 4.477 10 10-4.477 10-10 10zm0-2a8 8 0 100-16 8 8 0 000 16zM11 7h2v2h-2V7zm0 4h2v6h-2v-6z" fill="#fff"/></svg>
              </div>
              <h2 class="section-title">وصف الكورس</h2>
            </div>
            <div class="description-text">
              {{ course_content|raw }}
            </div>
          </div>
          <div class="gradient-overlay">
            <p class="show-more-btn">عرض المزيد</p>
          </div>
        </div>
        {% endif %}

        {# ===== WHAT YOU'LL LEARN ===== #}
        {% if course_benefits and course_benefits|trim %}
        <div class="section-card learning-card">
          <div class="section-header">
            <div class="section-icon-box">
              <svg width="24" height="24" fill="#fff" viewBox="0 0 24 24"><path d="M20 6h-4V4c0-1.11-.89-2-2-2h-4c-1.11 0-2 .89-2 2v2H4c-1.11 0-1.99.89-1.99 2L2 19c0 1.11.89 2 2 2h16c1.11 0 2-.89 2-2V8c0-1.11-.89-2-2-2zm-6 0h-4V4h4v2z"/></svg>
            </div>
            <h2 class="section-title">ماذا ستتعلم في هذه الدورة؟</h2>
          </div>
          <div class="learning-grid">
            {% set benefits_array = course_benefits|split('\n')|filter(b => b|trim) %}
            {% set half_count = (benefits_array|length / 2)|round %}
            <div class="learning-column">
              {% for benefit in benefits_array|slice(0, half_count) %}
                {% if benefit|trim %}
                <div class="learning-item">
                  <svg class="check-icon" width="20" height="20" fill="none" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" fill="#999EB2"/><path d="M10.58 15.58C10.38 15.58 10.19 15.5 10.05 15.36L7.22 12.53C6.93 12.24 6.93 11.76 7.22 11.47C7.51 11.18 7.99 11.18 8.28 11.47L10.58 13.77L15.72 8.63C16.01 8.34 16.49 8.34 16.78 8.63C17.07 8.92 17.07 9.4 16.78 9.69L11.11 15.36C10.97 15.5 10.78 15.58 10.58 15.58Z" fill="#fff"/></svg>
                  <p class="learning-text">{{ benefit|trim }}</p>
                </div>
                {% endif %}
              {% endfor %}
            </div>
            <div class="learning-column">
              {% for benefit in benefits_array|slice(half_count) %}
                {% if benefit|trim %}
                <div class="learning-item">
                  <svg class="check-icon" width="20" height="20" fill="none" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" fill="#999EB2"/><path d="M10.58 15.58C10.38 15.58 10.19 15.5 10.05 15.36L7.22 12.53C6.93 12.24 6.93 11.76 7.22 11.47C7.51 11.18 7.99 11.18 8.28 11.47L10.58 13.77L15.72 8.63C16.01 8.34 16.49 8.34 16.78 8.63C17.07 8.92 17.07 9.4 16.78 9.69L11.11 15.36C10.97 15.5 10.78 15.58 10.58 15.58Z" fill="#fff"/></svg>
                  <p class="learning-text">{{ benefit|trim }}</p>
                </div>
                {% endif %}
              {% endfor %}
            </div>
          </div>
        </div>
        {% endif %}

        {# ===== COURSE CONTENT / CURRICULUM ===== #}
        {% if topics|length > 0 %}
        <div class="section-card course-content-card">
          <div class="section-header">
            <div class="section-icon-box">
              <svg width="24" height="24" fill="#fff" viewBox="0 0 24 24"><path d="M4 6H2v14c0 1.1.9 2 2 2h14v-2H4V6zm16-4H8c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm-8 12.5v-9l6 4.5-6 4.5z"/></svg>
            </div>
            <h2 class="section-title">محتوى الكورس</h2>
          </div>

          <div class="weeks-list">
            {% for topic in topics %}
            <div class="week-container {% if loop.first %}open{% endif %}">
              <div class="week-header">
                <div class="week-info">
                  <p class="week-title">{{ topic.title }}</p>
                  <div class="week-meta">
                    <span>{{ topic.contents|length }} مواضيع</span>
                    <span>-</span>
                    <span>{{ topic.contents|length }} ساعه</span>
                  </div>
                </div>
                <svg class="arrow-icon" width="20" height="20" fill="none" viewBox="0 0 24 24">
                  <path d="M6 9l6 6 6-6" stroke="#999EB2" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>

              <div class="lectures-list">
                {% for content in topic.contents %}
                <div class="lecture-item">
                  <div class="lecture-content">
                    <p class="lecture-title">{{ content.title }}</p>
                    {% if not is_enrolled %}
                      <svg class="lecture-icon" width="18" height="18" fill="none" viewBox="0 0 24 24">
                        <rect x="3" y="11" width="18" height="11" rx="2" stroke="#666b7a" stroke-width="1.5"/>
                        <path d="M7 11V7a5 5 0 0110 0v4" stroke="#666b7a" stroke-width="1.5" stroke-linecap="round"/>
                      </svg>
                    {% elseif content.type == 'tutor_lesson' or content.type == 'lesson' %}
                      <img class="lecture-icon" src="{{ theme_uri }}/assets/img/Subtract.png" alt="فيديو" />
                    {% elseif content.type == 'tutor_quiz' or content.type == 'quiz' %}
                      <svg class="lecture-icon" width="18" height="18" fill="none" viewBox="0 0 24 24">
                        <rect x="3" y="3" width="18" height="18" rx="3" stroke="#999EB2" stroke-width="1.5"/>
                        <path d="M9 12l2 2 4-4" stroke="#999EB2" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    {% else %}
                      <svg class="lecture-icon" width="18" height="18" fill="none" viewBox="0 0 24 24">
                        <path d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" stroke="#999EB2" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    {% endif %}
                  </div>
                  {% if content.duration %}
                  <div class="lecture-right">
                    <div class="lecture-duration">{{ content.duration }}</div>
                  </div>
                  {% endif %}
                </div>
                {% endfor %}
              </div>
            </div>
            {% endfor %}
          </div>
        </div>
        {% endif %}

        {# ===== REVIEWS ===== #}
        {% if course_reviews|length > 0 %}
        <div class="section-card reviews-section">
          <div class="reviews-header-row">
            <div class="section-header">
              <div class="section-icon-box section-icon-box-gold">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="#ffbb54"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              </div>
              <h2 class="section-title">تقييمات الطلاب</h2>
            </div>
            <div class="reviews-summary-inline">
              <span class="reviews-avg-big">{{ rating_avg }}</span>
              <span class="reviews-avg-label">من 5 ({{ rating_count }} تقييم)</span>
            </div>
          </div>

          {# Rating Bars #}
          <div class="ratings-bars">
            {% for i in 5..1 %}
              {% set r_count = 0 %}
              {% for review in course_reviews %}
                {% if review.rating == i %}
                  {% set r_count = r_count + 1 %}
                {% endif %}
              {% endfor %}
              {% set pct = r_count > 0 ? (r_count / course_reviews|length * 100)|round : 0 %}
              <div class="rating-bar-row">
                <div class="rating-bar-stars">
                  {% for j in 1..5 %}
                    <svg width="14" height="14" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" fill="{% if j <= i %}#ffbb54{% else %}rgba(255,255,255,0.08){% endif %}"/></svg>
                  {% endfor %}
                </div>
                <div class="rating-bar-track">
                  <div class="rating-bar-fill" style="width: {{ pct }}%"></div>
                </div>
                <span class="rating-bar-pct">{{ pct }}%</span>
              </div>
            {% endfor %}
          </div>

          {# Review Cards #}
          <div class="review-cards" id="reviews-container">
            {% for review in course_reviews %}
            <div class="review-card {% if loop.index > 2 %}hidden-review{% endif %}">
              <div class="review-card-content">
                <div class="review-header">
                  <div class="review-avatar">
                    <img src="{{ review.avatar ?: theme_uri ~ '/assets/img/ellipse1.png' }}" alt="{{ review.author }}" />
                  </div>
                  <div class="review-meta">
                    <p class="user-name">{{ review.author }}</p>
                    <div class="review-stars">
                      {% for i in 1..5 %}
                        <svg width="14" height="14" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" fill="{% if i <= review.rating %}#ffbb54{% else %}rgba(255,255,255,0.08){% endif %}"/></svg>
                      {% endfor %}
                      <span class="review-date">{{ review.date|date('d/m/Y') }}</span>
                      {% if review.pending|default(false) %}
                        <span class="review-pending-badge">قيد المراجعة</span>
                      {% endif %}
                    </div>
                  </div>
                </div>
                <div class="review-text">
                  <p {% if review.content|length > 200 %}data-full="{{ review.content|e('html_attr') }}" data-short="{{ (review.content|slice(0, 200) ~ '...')|e('html_attr') }}"{% endif %}>
                    {{ review.content|slice(0, 200) }}{% if review.content|length > 200 %}... <button type="button" class="show-more-review">عرض المزيد</button>{% endif %}
                  </p>
                </div>
              </div>
            </div>
            {% endfor %}
          </div>
          
          {% if course_reviews|length > 2 %}
          <div class="reviews-load-more-wrapper">
            <button type="button" class="reviews-load-more-btn" id="load-more-reviews">
              <span>عرض المزيد من التقييمات</span>
              <span class="reviews-count">({{ course_reviews|length - 2 }} تقييم إضافي)</span>
            </button>
          </div>
          {% endif %}
        </div>
        {% endif %}

        {# ===== ADD REVIEW FORM ===== #}
        {% if can_write_review %}
        <div class="section-card add-review-section">
          <div class="card-content">
            <div class="section-header">
              <div class="section-icon-box">
                <svg width="24" height="24" fill="#fff" viewBox="0 0 24 24"><path d="M20 2H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h14l4 4V4c0-1.1-.9-2-2-2zm-2 12H6v-2h12v2zm0-3H6V9h12v2zm0-3H6V6h12v2z"/></svg>
              </div>
              <h2 class="section-title">{% if user_review %}تعديل تقييمك{% else %}أضف تقييمك للكورس{% endif %}</h2>
            </div>
            <div class="add-review-form">
              <form method="post" class="tutor-review-form" id="tutor-review-form">
                <input type="hidden" name="course_id" value="{{ course.ID }}"/>
                <input type="hidden" name="review_id" value="{{ user_review.id|default('') }}"/>
                <input type="hidden" name="action" value="tutor_place_rating"/>
                <input type="hidden" name="{{ tutor_nonce_field }}" value="{{ tutor_nonce }}"/>
                <div class="form-group star-rating-group">
                  <label class="form-label">التقييم</label>
                  <div class="star-rating-input" id="star-rating-input">
                    {% for i in 1..5 %}
                    <svg class="star-icon {% if user_review and i <= user_review.rating %}filled{% endif %}" data-rating="{{ i }}" viewBox="0 0 24 24" fill="none">
                      <path d="M12 2l2.9 6.26L21.9 9.27l-5 3.86L18 21l-6-3.16L6 21l1.1-7.87-5-3.86 6.99-0.99L12 2z" />
                    </svg>
                    {% endfor %}
                    <input type="hidden" name="tutor_rating_gen_input" id="tutor_rating_gen_input" value="{{ user_review.rating|default(0) }}"/>
                  </div>
                </div>
                <div class="form-group">
                  <label class="form-label">تقييمك</label>
                  <textarea name="review" class="review-textarea" placeholder="اكتب تقييمك هنا..." rows="4">{{ user_review.content|default('') }}</textarea>
                </div>
                <div class="form-group">
                  <button type="submit" class="submit-review-btn">
                    <span>{% if user_review %}تحديث التقييم{% else %}إرسال التقييم{% endif %}</span>
                  </button>
                </div>
                <div class="review-message" id="review-message" style="display: none;"></div>
              </form>
            </div>
          </div>
        </div>
        {% elseif is_enrolled and not is_user_logged_in %}
        <div class="section-card add-review-section">
          <div class="card-content">
            <div class="section-header">
              <div class="section-icon-box">
                <svg width="24" height="24" fill="#fff" viewBox="0 0 24 24"><path d="M20 2H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h14l4 4V4c0-1.1-.9-2-2-2z"/></svg>
              </div>
              <h2 class="section-title">أضف تقييمك للكورس</h2>
            </div>
            <div class="add-review-form">
              <p class="login-required-message">يجب تسجيل الدخول أولًا قبل إضافة تقييم.</p>
            </div>
          </div>
        </div>
        {% endif %}

      </div>
    </main>

    {% include 'components/footer.twig' %}
    {% include 'components/whatsapp-button.twig' %}

    <script>
        window.ajaxurl = '{{ site.url }}/wp-admin/admin-ajax.php';
    </script>
    {{ fn('wp_footer') }}
  </body>
</html>
